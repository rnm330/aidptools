{
  "manifest_version": 3,
  "name": "小羊AIDP做题工具",
  "version": "0.2.1",
  "description": "让每天的牛马生活过得更轻松一点吧。",
  "icons": {
    "32": "/icon.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://aidp.bytedance.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://aidp.bytedance.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "style.css"
      ]
    }
  ]
}